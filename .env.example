# ─────────────────────────────────────────────────────────────
# InvoiceFi-Stellar – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=invoicefi
POSTGRES_USER=invoicefi
POSTGRES_PASSWORD=change_me_in_production

# Prisma / NestJS connection string (auto-constructed in compose,
# but set this for local non-Docker development)
DATABASE_URL=postgresql://invoicefi:change_me_in_production@localhost:5432/invoicefi

# ── Stellar ──────────────────────────────────────────────────
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
STELLAR_RPC_URL=http://localhost:8001
HORIZON_URL=http://localhost:8000

# ── Backend ──────────────────────────────────────────────────
PORT=4000
JWT_SECRET=change_me_to_a_strong_random_secret

# ── Redis (for BullMQ) ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── SMTP (for Email Notifications) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@invoicefi.com

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_HORIZON_URL=http://localhost:8000
