# ─────────────────────────────────────────────────────────────────────────────
# InvoiceFi-Stellar – Environment Variables Reference
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# See CONTRIBUTING.md for a full setup walkthrough.
# ─────────────────────────────────────────────────────────────────────────────


# ── Runtime environment ───────────────────────────────────────────────────────
# Controls NestJS and Next.js behaviour (logging level, error detail, etc.).
# Values: development | staging | production
NODE_ENV=development


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# These three values are used by the postgres Docker container to create the
# database on first start. They must match the credentials in DATABASE_URL.

# Name of the database to create / connect to.
POSTGRES_DB=invoicefi

# PostgreSQL username.
POSTGRES_USER=invoicefi

# PostgreSQL password. Change this before any network-accessible deployment.
# Generate a strong value with: openssl rand -hex 24
POSTGRES_PASSWORD=change_me_in_production

# Full Prisma / NestJS connection string.
# When running via Docker Compose this is overridden automatically — the
# compose file sets the host to the internal service name `postgres`.
# Only set this manually for non-Docker local development.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://invoicefi:change_me_in_production@localhost:5432/invoicefi


# ── Stellar network ───────────────────────────────────────────────────────────
# Network passphrase used to sign and verify transactions. Must match the
# network the Soroban RPC node is running.
#
# Standalone (local Docker):  "Standalone Network ; February 2017"
# Testnet:                    "Test SDF Network ; September 2015"
# Mainnet:                    "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"

# URL of the Soroban RPC endpoint. Used by the backend event listener and
# by the Stellar CLI for contract deployment.
# Docker Compose default (standalone): http://localhost:8001
# Testnet public RPC:                  https://soroban-testnet.stellar.org
STELLAR_RPC_URL=http://localhost:8001

# URL of the Horizon REST API. Used by the frontend and backend for account
# and transaction queries.
# Docker Compose default (standalone): http://localhost:8000
# Testnet Horizon:                     https://horizon-testnet.stellar.org
HORIZON_URL=http://localhost:8000


# ── Backend (NestJS) ──────────────────────────────────────────────────────────
# TCP port the NestJS server listens on inside the container (and on the host
# when running without Docker).
PORT=4000

# Secret used to sign JWT tokens for wallet-based authentication.
# Must be at least 32 characters. Change this before any deployment.
# Generate a secure value with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret


# ── Soroban contract IDs ──────────────────────────────────────────────────────
# Contract ID returned by `stellar contract deploy` for the invoice contract.
# The backend settlement event listener filters Soroban events by this ID.
# Leave empty to receive events from all contracts (not recommended in prod).
# See CONTRIBUTING.md → "Deploy contracts to the local standalone network".
INVOICE_CONTRACT_ID=

# How often (in milliseconds) the settlement event listener polls the
# Soroban RPC for new events. Lower values increase responsiveness but add
# more RPC load. Default: 5000 (5 seconds).
SETTLEMENT_POLL_INTERVAL_MS=5000

# Maximum number of retry attempts when processing a settlement event fails
# (e.g. transient RPC or DB errors). Default: 3.
SETTLEMENT_MAX_ATTEMPTS=3

# Base delay (in milliseconds) for the exponential back-off between retry
# attempts. Actual delay = SETTLEMENT_RETRY_BASE_MS * 2^attempt. Default: 500.
SETTLEMENT_RETRY_BASE_MS=500
INVOICE_CONTRACT_ID=

# ── Compliance / regulatory exports (issue #89) ──────────────
# Stellar secret seed (S...) for the ed25519 key that signs exports.
# REQUIRED in production; if unset an ephemeral key is generated at startup
# (a warning is logged) and signatures will not survive a restart.
COMPLIANCE_SIGNING_SECRET=
# Reporting asset for export amounts and its minor-unit precision.
COMPLIANCE_ASSET_CODE=USDC
COMPLIANCE_ASSET_DECIMALS=7
# Default FATF Travel Rule threshold, in whole asset units (decimal).
FATF_TRAVEL_RULE_THRESHOLD=1000

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# Base URL of the Horizon API, as seen from the browser.
# Used for account balance queries and transaction submission.
NEXT_PUBLIC_HORIZON_URL=http://localhost:8000

# ── Vault-init seed values (used by vault-init container only) ─
# These are passed to scripts/vault-init.sh to seed Vault in dev.
# They are never read by the application itself.
POSTGRES_DB=invoicefi
POSTGRES_USER=invoicefi
POSTGRES_PASSWORD=change_me_in_production
JWT_SECRET=change_me_to_a_strong_random_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@invoicefi.com
