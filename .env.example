# ─────────────────────────────────────────────────────────────
# InvoiceFi-Stellar – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# SECRETS MANAGEMENT NOTICE
# ──────────────────────────
# All sensitive values (database credentials, JWT secret, SMTP
# password, API keys) are now stored in HashiCorp Vault and are
# fetched at application startup. They are NO LONGER read from
# environment variables in the application code.
#
# The variables below are the ONLY ones the application and
# docker-compose need at boot time. Everything else comes from
# Vault via VAULT_ADDR + VAULT_TOKEN (dev) or AppRole (prod).
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── HashiCorp Vault connection ────────────────────────────────
# Address of the Vault server. In local Docker Compose this is
# http://vault:8200. In production, point to your Vault cluster.
VAULT_ADDR=http://localhost:8200

# Root token for local dev mode ONLY.
# In production, use AppRole: set VAULT_ROLE_ID + VAULT_SECRET_ID
# and leave VAULT_TOKEN unset.
VAULT_TOKEN=dev-only-root-token

# AppRole credentials (production / staging). Leave blank for dev.
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── Non-secret runtime config ─────────────────────────────────
# These values are not sensitive and remain in env vars.
PORT=4000
STELLAR_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
STELLAR_RPC_URL=http://localhost:8001
HORIZON_URL=http://localhost:8000
SETTLEMENT_POLL_INTERVAL_MS=5000
SETTLEMENT_MAX_ATTEMPTS=3
SETTLEMENT_RETRY_BASE_MS=500
INVOICE_CONTRACT_ID=

# ── Frontend (public, non-secret) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_HORIZON_URL=http://localhost:8000

# ── Vault-init seed values (used by vault-init container only) ─
# These are passed to scripts/vault-init.sh to seed Vault in dev.
# They are never read by the application itself.
POSTGRES_DB=invoicefi
POSTGRES_USER=invoicefi
POSTGRES_PASSWORD=change_me_in_production
JWT_SECRET=change_me_to_a_strong_random_secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@invoicefi.com
