// Prisma schema for the InvoiceFi-Stellar backend.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  PENDING
  FUNDED
  REPAID
  DEFAULTED
}

/// Off-chain mirror of an on-chain invoice. `onchainId` is the invoice id
/// allocated by the Soroban invoice contract and is the join key used by the
/// settlement event listener.
model Invoice {
  id           Int           @id @default(autoincrement())
  onchainId    BigInt        @unique
  status       InvoiceStatus @default(PENDING)
  faceValue    BigInt
  /// @privacy retention: 365 days after settlement or creation, whichever is later; legal_basis: contract-performance, settlement-operations, fraud-prevention
  farmer       String
  /// @privacy retention: 365 days after settlement or creation, whichever is later; legal_basis: contract-performance, settlement-operations, fraud-prevention
  investor     String?
  /// Ledger sequence in which the on-chain settlement was observed.
  settledLedger Int?
  settledAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([farmer])
  @@index([investor])
}

/// Singleton row tracking the last Soroban ledger the event listener has
/// processed, so polling resumes from the correct cursor after a restart.
model SyncCursor {
  id         Int      @id @default(1)
  lastLedger Int      @default(0)
  updatedAt  DateTime @updatedAt
}
